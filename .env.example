# Kopiraj ovaj fajl u .env i popuni vrednosti

# Meteor WebSocket server
METEOR_WSS_URL=wss://tvi.meteor.teaminoving2.rs

# Cena po satu (iz profila korisnika)
PRICE_PER_HOUR=2300

# Podrazumevani projekat (activities_id i requests_id iz DevTools kada ručno dodaš vreme)
DEFAULT_ACTIVITIES_ID=POPUNI
DEFAULT_REQUESTS_ID=POPUNI

# AI backend: gemini | groq | ollama
AI_BACKEND=gemini
GEMINI_API_KEY=POPUNI
GEMINI_MODEL=gemini-2.5-flash
OLLAMA_URL=http://192.168.0.246:11434
OLLAMA_MODEL=llama3.1:8b
